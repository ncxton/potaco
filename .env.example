# Potaco environment variables
# Copy to .env and fill in your values, or set these in your shell.

# Override the active provider (openai, fal, vercel)
POTACO_PROVIDER=openai

# API key for the active provider
POTACO_API_KEY=your-api-key-here

# Override the default model for the active provider
POTACO_MODEL=gpt-image-2

# Override the provider's base URL
POTACO_BASE_URL=https://api.openai.com

# Max retry attempts for API calls
POTACO_RETRIES=2

# Request timeout in seconds
POTACO_TIMEOUT=120

# Disable interactive TUI flows (set to 1 for CI, scripts, agents)
POTACO_NON_INTERACTIVE=0
